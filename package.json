{
  "name": "genui-techtalk",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:json-render": "cd apps/json-render-demo && npm run dev",
    "dev:vercel-ai": "cd apps/vercel-ai-demo && npm run dev",
    "dev:codegen-ui": "cd apps/codegen-ui && npm run dev",
    "dev:all": "concurrently \"npm run dev:json-render\" \"npm run dev:vercel-ai\" \"npm run dev:codegen-ui\"",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.8.1",
    "turbo": "^2.9.3"
  },
  "packageManager": "npm@10.0.0"
}

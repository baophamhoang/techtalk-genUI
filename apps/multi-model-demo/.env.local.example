# API keys are NOT required for the simulation

# For real implementation with OpenRouter (Optional)
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# For individual providers (Optional)
# OPENAI_API_KEY=sk-your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# MINIMAX_API_KEY=your-minimax-api-key-here
# KIMI_API_KEY=your-kimi-api-key-here

# Note: This demo runs entirely on simulated data
# No actual API calls are made during the presentation